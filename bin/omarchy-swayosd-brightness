#!/bin/bash

# Display brightness level using SwayOSD on the current monitor.
# Niri wrapper: replaces hyprctl monitors query with niri msg equivalent.

source "$(dirname "$0")/../lib.sh"

if ! is_niri; then
  exec ~/.local/share/omarchy/bin/omarchy-swayosd-brightness "$@"
fi

percent="$1"

progress="$(awk -v p="$percent" 'BEGIN{printf "%.2f", p/100}')"
[[ $progress == "0.00" ]] && progress="0.01"

swayosd-client \
  --monitor "$(niri msg -j focused-output | jq -r '.name')" \
  --custom-icon display-brightness \
  --custom-progress "$progress" \
  --custom-progress-text "${percent}%"
