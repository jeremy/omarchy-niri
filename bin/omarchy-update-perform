#!/bin/bash

# Perform system update with idle suppression.
# Niri wrapper: replaces hyprctl tagwindow idle suppression with swayidle stop/restart.

source "$(dirname "$0")/../lib.sh"

if ! is_niri; then
  exec ~/.local/share/omarchy/bin/omarchy-update-perform "$@"
fi

set -e

# Suppress idle during updates by stopping swayidle
pkill -x swayidle 2>/dev/null || true

# Capture update logs (CLICOLOR_FORCE keeps gum styled when stdout is piped through tee)
export CLICOLOR_FORCE=1
exec > >(tee "/tmp/omarchy-update.log") 2>&1

# Perform all update steps
omarchy-update-keyring
omarchy-update-available-reset
omarchy-update-system-pkgs
omarchy-migrate
omarchy-update-aur-pkgs
omarchy-update-orphan-pkgs
omarchy-hook post-update

omarchy-update-analyze-logs

omarchy-update-restart

# Re-enable idle after updates
omarchy-restart-hypridle
